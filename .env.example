# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://aloclinica.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Email (Brevo)
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM_ADDRESS=noreply@telemedicinaaloclinica.sbs
EMAIL_FROM_NAME=AloClínica

# Payment Gateway (Asaas)
ASAAS_API_KEY=your_asaas_api_key_here
NEXT_PUBLIC_ASAAS_ENVIRONMENT=sandbox

# Video (Daily.co)
DAILY_API_KEY=your_daily_api_key_here
DAILY_ROOM_NAME_PREFIX=aloclinica

# KYC Provider
UNICO_TOKEN=your_unico_token_here

# VPS
VPS_SSH_HOST=72.62.138.208
VPS_SSH_USER=root
VPS_APP_PORT=3010

# Environment
NODE_ENV=development
